/* EvoOS Linker Script - Rust Kernel */

ENTRY(_start)

SECTIONS
{
    . = 0x100000;   /* 1MB - kernel load address */

    .text : {
        *(.text .text.*)
    }

    .rodata : {
        *(.rodata .rodata.*)
    }

    .data : {
        *(.data .data.*)
    }

    .bss : {
        *(.bss .bss.*)
    }

    /DISCARD/ : {
        *(.eh_frame)
        *(.comment)
    }
}
